Algoritmo ContarDinero
    Definir m2e, m1e, m50c, m20c, m10c Como Entero
    Definir total_centimos, euros_totales, centimos_restantes Como Entero
    Escribir "Monedas de 2 euros:"
    Leer m2e
    Escribir "Monedas de 1 euro:"
    Leer m1e
    Escribir "Monedas de 50 céntimos:"
    Leer m50c
    Escribir "Monedas de 20 céntimos:"
    Leer m20c
    Escribir "Monedas de 10 céntimos:"
    Leer m10c
    
    total_centimos <- (m2e * 200) + (m1e * 100) + (m50c * 50) + (m20c * 20) + (m10c * 10)
    euros_totales <- trunc(total_centimos / 100)
    centimos_restantes <- total_centimos MOD 100
    
    Escribir "Tienes un total de ", euros_totales, " euros y ", centimos_restantes, " céntimos."
FinAlgoritmo
